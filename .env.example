# API
PORT=5000
DATABASE_URL=postgresql://usuario:senha@localhost:5432/verallia_cert

# Frontend
BASE_PATH=/
API_PROXY_TARGET=http://localhost:5000

# PDF storage
# Production on Vercel: use Supabase Storage so uploaded/generated PDFs persist.
SUPABASE_URL=https://seu-projeto.supabase.co
# Use only on the server/Vercel env vars. Never expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=certificados

# Local fallback: if Supabase and DEFAULT_OBJECT_STORAGE_BUCKET_ID are empty,
# PDFs are stored locally under LOCAL_STORAGE_DIR.
LOCAL_STORAGE_DIR=./uploads

# Optional Replit/Object Storage fallback.
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# Replit/Object Storage optional variables used by objectStorage.ts
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
